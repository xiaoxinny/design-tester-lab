# design-tester-lab - environment variables
#
# The app runs in one of two modes, chosen automatically:
#   - Supabase Cloud mode: when SUPABASE variables are set
#   - Local mode: when they are absent (falls back to SQLite + env-var bootstrap user)
#
# Generate secrets with: openssl rand -base64 32

# ============================================================
# Required in BOTH modes
# ============================================================

# AES-256-GCM key for encrypting BYOK credentials at rest.
# Format: base64-encoded 32-byte key. Generate with:
#   openssl rand -base64 32
# WARNING: short or malformed keys will be zero-padded silently and produce
# a deceptively-weak cipher. The app will refuse to boot if ENCRYPTION_KEY
# is missing or shorter than 32 bytes after base64 decoding.
ENCRYPTION_KEY=

# HMAC secret for session cookie signing (use a DIFFERENT value than ENCRYPTION_KEY)
SESSION_SECRET=

# Server port (default 3030)
PORT=3030

# Node environment
NODE_ENV=production

# ============================================================
# Supabase Cloud mode (when these are set, app uses Supabase)
# Leave ALL of them blank to fall back to local mode.
# ============================================================

# Supabase project URL
# Example: https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key - safe to expose to client
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key - SERVER ONLY, never expose to client
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Postgres connection string (for migrations + seed scripts ONLY).
# Find at: Supabase dashboard -> Settings -> Database -> Connection string -> URI
# Format: postgresql://postgres:<password>@<host>:5432/postgres
# NEVER expose to the browser; server-side only.
SUPABASE_DB_URL=

# ============================================================
# Local mode (used only when Supabase vars above are empty)
# ============================================================

# SQLite database file path (relative to project root)
DATABASE_URL=./data/design-tester-lab.db

# Where uploaded screenshots / generated HTML artifacts live
STORAGE_DIR=./data/storage

# Where the augmentation YAML files live (bundled into image at build time)
AUGMENTATIONS_DIR=./content/augmentations

# Default user email for local mode (read once at first startup,
# ignored after the first user exists in the database)
LOCAL_DEFAULT_USER_EMAIL=

# Default user password for local mode (read once at first startup,
# 12+ characters recommended; change through /settings after first login)
LOCAL_DEFAULT_USER_PASSWORD=

# ============================================================
# Optional
# ============================================================

# App URL - used for share-link canonical URLs and email links.
# Set to your Coolify public URL or leave blank for local dev.
NEXT_PUBLIC_APP_URL=

# Log level (trace | debug | info | warn | error)
LOG_LEVEL=info

# Local mode only: set to "true" to disable auth entirely.
# DANGEROUS: anyone who can reach the URL has full access.
# Only use on isolated dev machines behind a VPN or firewall.
AUTH_DISABLED=false
