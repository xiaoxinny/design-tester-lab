  "architecture_patterns": {
    "A_figma_native_workspace": {
      "tools": ["Figma Design Agent", "Figma Make", "Figma Motion", "Code Layers", "MCP server", "Code Connect"],
      "thesis": "Agent + canvas + tokens/components + code layers + motion + MCP bridge = closest to full deliverable but lacks a11y/rationale/content voice",
      "primary_source": "https://www.figma.com/blog/the-figma-agent-is-here/"
    },
    "B_design_to_code": {
      "tools": ["Builder.io Visual Copilot", "Anima", "Locofy", "TeleportHQ", "Figma Dev Mode"],
      "thesis": "Pipeline: Figma → specialized model → Mitosis IR → framework code. Tightest when DS exists in both. No rationale, motion, or a11y in output."
    },
    "C_prompt_to_code": {
      "tools": ["v0", "Bolt.new", "Lovable", "Replit Agent 4", "Claude Design", "Magic Patterns", "Motiff"],
      "thesis": "LLM-driven code generation. Output is JSX or multi-file code. Onboarding can read codebase/DS. No first-class rationale/motion/a11y artifacts."
    },
    "D_design_tools_with_native_ai": {
      "tools": ["Figma AI", "Sketch AI", "Adobe Firefly Design", "Magician (legacy)"],
      "thesis": "Output stays in native design tool format. Most reach parity with Pattern C minus live code."
    },
    "E_sitemap_wireframe_first": {
      "tools": ["Relume", "UX Pilot"],
      "thesis": "Starts with IA (sitemap + flows) before screens. Best at IA + wireframe + style guide. Relume exports directly into Figma/Webflow/Claude Design."
    },
    "F_code_native_design_systems": {
      "tools": ["shadcn/ui Registry", "Replit Skill", "Figma MCP", "Vercel Geist"],
      "thesis": "Design system is code-first (registry-item.json / SKILL.md / tokens.css). Models consume directly. This is the glue other patterns lack."
    }
  },
  "gap_ranking": [
    {
      "rank": 1,
      "missing_artifact": "design_rationale / design_intent_documentation",
      "evidence": "Every tool produces screens; almost none produces the *reasoning* for the screens. UXTigers: 'A prompt is not intent.'"
    },
    {
      "rank": 2,
      "missing_artifact": "motion_specs",
      "evidence": "Figma Motion (Config 2026) shipped as separate tool; motion isn't first-class in any AI generator. Timings buried in code as CSS transitions, invisible to design system."
    },
    {
      "rank": 3,
      "missing_artifact": "a11y_annotations / contrast_reports",
      "evidence": "v0 prompt mentions WCAG but doesn't export a11y layer. Google Stitch has known weak accessibility. Locofy mentions a11y via MCP but opt-in."
    },
    {
      "rank": 4,
      "missing_artifact": "content_voice_guidelines",
      "evidence": "Relume auto-fills wireframes with AI copy but no voice doc. Claude Design has tone but no exported style guide."
    },
    {
      "rank": 5,
      "missing_artifact": "real_prototyping_outside_figma",
      "evidence": "Figma's prototype is universal but locked-in. Claude Design prototypes are shareable HTML. v0/Bolt/Lovable prototypes are running apps — impressive but code-shaped."
    },
    {
      "rank": 6,
      "missing_artifact": "design_system_coherence_under_swarms",
      "evidence": "UXTigers: 'AI will produce many adequate screens incoherent in aggregate.' Only Motiff (Consistency Checker) and Replit (human-authored guardrails.md) come close."
    }
  ],
  "does_any_tool_produce_full_set": false,
  "closest_combination_workflow": "Relume (sitemap + wireframes + style guide) → Figma (Design Agent + Variables + components) → Figma Make (interactive prototype) → Figma Motion (choreography) → Claude Code or Replit Agent (production code via Skills/MCP)"
}
